# Mini program production build env.
# Copy to .env.production on the build machine or inject the same variables in CI.

# Option A: self-hosted backend. Must be HTTPS and added to WeChat request valid domains.
PROJECT_DOMAIN=https://api.example.com
WECHAT_USE_CLOUD_CONTAINER=false

# Option B: WeChat CloudBase container. Leave PROJECT_DOMAIN empty and set use-cloud true.
# PROJECT_DOMAIN=
# WECHAT_USE_CLOUD_CONTAINER=true

WECHAT_CLOUD_ENV_ID=replace-with-cloud-env-id
WECHAT_CLOUD_SERVICE_NAME=replace-with-cloud-service-name
WECHAT_CLOUD_STORAGE_PREFIX=task-images
