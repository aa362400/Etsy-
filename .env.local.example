# Mini program local development env
# Copy to .env.local before local debugging.

# Recommended for local H5 debug or local mini program network testing.
PROJECT_DOMAIN=http://127.0.0.1:3000
WECHAT_USE_CLOUD_CONTAINER=false

# Optional CloudBase mode for real mini program testing.
# PROJECT_DOMAIN=
# WECHAT_USE_CLOUD_CONTAINER=true
# WECHAT_CLOUD_ENV_ID=replace-with-cloud-env-id
# WECHAT_CLOUD_SERVICE_NAME=replace-with-cloud-service-name

WECHAT_CLOUD_STORAGE_PREFIX=task-images
