{
  "name": "admin-console",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-build-info.cjs",
    "dev": "vite --host 0.0.0.0 --port 5173",
    "generate:build-info": "node scripts/generate-build-info.cjs",
    "prebuild": "node scripts/generate-build-info.cjs",
    "build": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "pretsc": "node scripts/generate-build-info.cjs",
    "tsc": "node ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.5",
    "vite": "^4.2.0"
  }
}
