# Mini program build env example
# Copy to .env.local for local debug, or .env.production for release build.

# Option A: direct backend domain
# Use HTTPS in production and add it to WeChat request valid domains.
PROJECT_DOMAIN=https://api.example.com
WECHAT_USE_CLOUD_CONTAINER=false

# Option B: CloudBase container
# Leave PROJECT_DOMAIN empty and let the mini program call the container directly.
# PROJECT_DOMAIN=
# WECHAT_USE_CLOUD_CONTAINER=true
# WECHAT_CLOUD_ENV_ID=replace-with-cloud-env-id
# WECHAT_CLOUD_SERVICE_NAME=replace-with-cloud-service-name

# Shared upload prefix
WECHAT_CLOUD_STORAGE_PREFIX=task-images
